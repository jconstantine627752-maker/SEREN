# ─────────────────────────────────────────────
#  SEREN — Environment Configuration
# ─────────────────────────────────────────────

# Server
PORT=3000

# ─── Qdrant Vector Memory ─────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=seren_emotions

# ─── OpenAI Embeddings ────────────────────────
# Used for embedding felt-text into Qdrant vectors
# Model: text-embedding-3-small (1536 dimensions)
OPENAI_API_KEY=sk-...

# ─── Log Database ─────────────────────────────
# SQLite (default): relative path to .db file
# PostgreSQL:       postgres://user:pass@host:5432/dbname
DATABASE_URL=./seren.db

# ─── Plugin System ────────────────────────────
# Directory scanned for ESM plugin folders at startup
PLUGIN_DIR=./src/plugins
